{
  "name": "lets-ui-icons",
  "private": true,
  "description": "Monorepo for the Let's UI Icons design system.",
  "repository": {
    "type": "git",
    "url": "https://github.com/mateusvillain/lets-ui-icons.git"
  },
  "license": "MIT",
  "author": {
    "name": "Mateus Villain",
    "email": "mateus@mateusvillain.com",
    "url": "https://mateusvillain.com"
  },
  "scripts": {
    "pull": "pnpm --filter @lets-ui/icons pull",
    "build": "pnpm --filter @lets-ui/icons build && pnpm --filter @lets-ui/icons-web build && pnpm --filter @lets-ui/icons-webcomponents build",
    "dev": "pnpm --filter docs dev",
    "clean": "pnpm -r clean"
  },
  "lint-staged": {
    "*.{js,ts,css,json,md}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@eslint/css": "^0.14.1",
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4"
  }
}
